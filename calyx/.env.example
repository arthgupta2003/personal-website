# === Anthropic (required) ===
CALYX_ANTHROPIC_API_KEY=sk-ant-...
CALYX_CLAUDE_MODEL=claude-sonnet-4-20250514

# === YouTube (required) ===
# Download OAuth client_secret.json from GCP Console and place in state/tokens/
# Then run: uv run python scripts/auth_youtube.py

# === Spotify (required) ===
CALYX_SPOTIFY_CLIENT_ID=your_client_id
CALYX_SPOTIFY_CLIENT_SECRET=your_client_secret
CALYX_SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# === Gmail (required for newsletter scanning) ===
# Uses same GCP project as YouTube. Enable Gmail API.
# Then run: uv run python scripts/auth_gmail.py

# === Gemini (optional — enables grounded web search for source gap retro) ===
# Get from Google AI Studio: https://aistudio.google.com/apikey
CALYX_GEMINI_API_KEY=

# === Event Sources (optional — will scrape if no API key) ===
CALYX_EVENTBRITE_TOKEN=
CALYX_SONGKICK_API_KEY=

# === Email Sending (required) ===
CALYX_EMAIL_TO=you@gmail.com
CALYX_EMAIL_FROM=you@gmail.com
CALYX_SMTP_HOST=smtp.gmail.com
CALYX_SMTP_PORT=587
CALYX_SMTP_USER=you@gmail.com
CALYX_SMTP_PASSWORD=your_gmail_app_password

# === Location ===
CALYX_LOCATION_QUERY=Cambridge, MA
CALYX_ZIP_CODE=02139
CALYX_LATITUDE=42.3736
CALYX_LONGITUDE=-71.1097
CALYX_MAX_COMMUTE_MINUTES=30
