# === Anthropic (required) ===
RECOM_ANTHROPIC_API_KEY=sk-ant-...
RECOM_CLAUDE_MODEL=claude-sonnet-4-20250514

# === YouTube (required) ===
# Download OAuth client_secret.json from GCP Console and place in state/tokens/
# Then run: uv run python scripts/auth_youtube.py

# === Spotify (required) ===
RECOM_SPOTIFY_CLIENT_ID=your_client_id
RECOM_SPOTIFY_CLIENT_SECRET=your_client_secret
RECOM_SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# === Gmail (required for newsletter scanning) ===
# Uses same GCP project as YouTube. Enable Gmail API.
# Then run: uv run python scripts/auth_gmail.py

# === Gemini (optional — enables grounded web search for source gap retro) ===
# Get from Google AI Studio: https://aistudio.google.com/apikey
RECOM_GEMINI_API_KEY=

# === Event Sources (optional — will scrape if no API key) ===
RECOM_EVENTBRITE_TOKEN=
RECOM_SONGKICK_API_KEY=

# === Email Sending (required) ===
RECOM_EMAIL_TO=you@gmail.com
RECOM_EMAIL_FROM=you@gmail.com
RECOM_SMTP_HOST=smtp.gmail.com
RECOM_SMTP_PORT=587
RECOM_SMTP_USER=you@gmail.com
RECOM_SMTP_PASSWORD=your_gmail_app_password

# === Location ===
RECOM_LOCATION_QUERY=Cambridge, MA
RECOM_ZIP_CODE=02139
RECOM_LATITUDE=42.3736
RECOM_LONGITUDE=-71.1097
RECOM_MAX_COMMUTE_MINUTES=30
